// ============================================================
// ADD THIS BLOCK AT THE VERY TOP OF YOUR JENKINSFILE
// ============================================================
properties([
    pipelineTriggers([
        triggers: [
            // Keep your existing GitHub trigger (if any)
            [$class: 'GitHubPushTrigger'],
            
            // Add Generic Webhook Trigger for AWS Batch
            [
                $class: 'GenericTrigger',
                genericVariables: [
                    [key: 'triggerSource', value: '$.source'],
                    [key: 'modelVersion', value: '$.model_version']
                ],
                token: 'ct-trigger-token',  // Must match token in CT repo
                // Optional: Print the payload for debugging
                printContributedVariables: true,
                printPostContent: true
            ]
        ]
    ])
])

// ============================================================
// YOUR EXISTING PIPELINE (starts here)
// ============================================================
pipeline {
    agent any
    
    environment {
        // AWS Credentials (keep same)
        ECR_REPOSITORY = credentials('ECR_REPOSITORY')
        AWS_ACCOUNT_ID = credentials('AWS_ACCOUNT_ID')
        AWS_ACCESS_KEY_ID = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
        
        // ECS Configuration
        AWS_REGION = 'us-east-1'
        ECS_CLUSTER = 'chest-ct-cluster'
        ECS_SERVICE = 'chest-ct-service'
        MODEL_BUCKET = 'chest-ct-models-155407238003'
    }
    
    stages {
        // NEW STAGE: Check trigger source (optional, for debugging)
        stage('Check Trigger Source') {
            steps {
                script {
                    if (env.triggerSource == 'aws-batch') {
                        echo "🔄 This deployment was triggered by AWS Batch retraining"
                        echo "📦 New model version: ${env.modelVersion}"
                    } else if (env.triggerSource == 'github-push') {
                        echo "📦 This deployment was triggered by GitHub push"
                    } else {
                        echo "📦 This deployment was triggered manually or by another source"
                    }
                }
            }
        }
        
        // Checkout code
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code checked out from GitHub"
            }
        }
        
        // Download model from S3
        stage('Download Model from S3') {
            steps {
                script {
                    sh """
                        # Download the latest production model
                        aws s3 cp s3://${MODEL_BUCKET}/production/model.h5 model.h5 || \
                        aws s3 cp s3://${MODEL_BUCKET}/model.h5 model.h5 || \
                        echo "No model found, using default"
                    """
                    echo "✅ Model downloaded from S3"
                }
            }
        }
        
        // Continuous Integration (optional)
        stage('Continuous Integration') {
            steps {
                script {
                    echo "Linting repository"
                    echo "Running unit tests"
                }
            }
        }

        // Login to ECR
        stage('Login to ECR') {
            steps {
                script {
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                }
            }
        }

        // Build Image
        stage('Build Image') {
            steps {
                script {
                    sh "docker build -t ${ECR_REPOSITORY}:latest ."
                }
            }
        }

        // Push Image
        stage('Push Image') {
            steps {
                script {
                    sh "docker push ${ECR_REPOSITORY}:latest"
                }
            }
        }

        // Deploy to ECS
        stage('Deploy to ECS') {
            steps {
                script {
                    sh """
                        aws ecs update-service \
                            --cluster ${ECS_CLUSTER} \
                            --service ${ECS_SERVICE} \
                            --force-new-deployment \
                            --region ${AWS_REGION}
                        
                        aws ecs wait services-stable \
                            --cluster ${ECS_CLUSTER} \
                            --services ${ECS_SERVICE} \
                            --region ${AWS_REGION}
                    """
                    echo "✅ ECS service updated"
                }
            }
        }
        
        // Health Check
        stage('Health Check') {
            steps {
                script {
                    sh """
                        sleep 10
                        curl -f http://\$(cd terraform && terraform output -raw load_balancer_dns 2>/dev/null || echo 'pending')/health || echo 'Health check pending'
                    """
                    echo "✅ Health check completed"
                }
            }
        }
    }

    post {
        success {
            echo """
            ========================================
            🎉 DEPLOYMENT SUCCESSFUL! 🎉
            ========================================
            ECS Cluster: ${ECS_CLUSTER}
            ECS Service: ${ECS_SERVICE}
            Trigger Source: ${env.triggerSource ?: 'manual'}
            ========================================
            """
        }
        failure {
            echo """
            ========================================
            ❌ DEPLOYMENT FAILED! ❌
            ========================================
            Check Jenkins console for details.
            ========================================
            """
        }
        always {
            sh 'docker system prune -f'
        }
    }
}
