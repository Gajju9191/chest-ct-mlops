pipeline {
    agent any
    
    environment {
        AWS_REGION = 'us-east-1'
        ECR_REPOSITORY = 'chest-ct-api'
        ECS_CLUSTER = 'chest-ct-cluster'
        ECS_SERVICE = 'chest-ct-service'
    }
    
    stages {
        stage('Fetch Secrets from AWS Secrets Manager') {
            steps {
                script {
                    // Fetch secrets using AWS CLI
                    def secrets = sh(
                        script: """
                            aws secretsmanager get-secret-value \
                                --secret-id chest-ct/deployment/credentials \
                                --query SecretString \
                                --output text
                        """,
                        returnStdout: true
                    ).trim()
                    
                    def secretsJson = readJSON text: secrets
                    env.MODEL_BUCKET = secretsJson.models_bucket
                    env.MLFLOW_TRACKING_URI = secretsJson.mlflow_tracking_uri
                    env.AWS_ACCOUNT_ID = secretsJson.aws_account_id
                }
            }
        }
        
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code checked out from GitHub"
            }
        }
        
        stage('Run DVC Pipeline') {
            steps {
                script {
                    sh """
                        # Activate environment
                        conda activate chest-ct-ecs || source activate chest-ct-ecs
                        
                        # Pull data
                        dvc pull
                        
                        # Run full pipeline with new stages
                        dvc repro
                        
                        # Push artifacts
                        dvc push
                    """
                    echo "✅ DVC pipeline completed"
                }
            }
        }
        
        stage('Upload Model to S3') {
            steps {
                script {
                    sh """
                        aws s3 cp artifacts/training/model.h5 s3://${env.MODEL_BUCKET}/model.h5
                        aws s3 cp artifacts/training/model.h5 s3://${env.MODEL_BUCKET}/production/model.h5
                        
                        # Also upload drift report
                        aws s3 cp artifacts/drift_reports/latest_drift.json s3://${env.MODEL_BUCKET}/drift_reports/latest_drift.json
                    """
                    echo "✅ Model uploaded to S3"
                }
            }
        }
        
        stage('Login to ECR') {
            steps {
                script {
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${env.AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                }
            }
        }

        stage('Build Image') {
            steps {
                script {
                    sh "docker build -t ${ECR_REPOSITORY}:latest ."
                }
            }
        }

        stage('Push Image') {
            steps {
                script {
                    sh """
                        docker tag ${ECR_REPOSITORY}:latest ${env.AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:latest
                        docker push ${env.AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:latest
                    """
                }
            }
        }

        stage('Deploy to ECS') {
            steps {
                script {
                    sh """
                        aws ecs update-service \
                            --cluster ${ECS_CLUSTER} \
                            --service ${ECS_SERVICE} \
                            --force-new-deployment \
                            --region ${AWS_REGION}
                        
                        aws ecs wait services-stable \
                            --cluster ${ECS_CLUSTER} \
                            --services ${ECS_SERVICE} \
                            --region ${AWS_REGION}
                    """
                    echo "✅ ECS service updated"
                }
            }
        }
        
        stage('Health Check') {
            steps {
                script {
                    sh """
                        sleep 10
                        curl -f http://\$(cd terraform && terraform output -raw load_balancer_dns 2>/dev/null || echo 'pending')/health || echo '⚠️ Health check pending'
                    """
                    echo "✅ Health check completed"
                }
            }
        }
    }

    post {
        success {
            echo """
            ========================================
            🎉 DEPLOYMENT SUCCESSFUL! 🎉
            ========================================
            ECS Cluster: ${ECS_CLUSTER}
            ECS Service: ${ECS_SERVICE}
            Model Bucket: ${env.MODEL_BUCKET}
            ========================================
            """
        }
        failure {
            echo """
            ========================================
            ❌ DEPLOYMENT FAILED! ❌
            ========================================
            Check Jenkins console for details.
            ========================================
            """
        }
        always {
            sh 'docker system prune -f || true'
        }
    }
}