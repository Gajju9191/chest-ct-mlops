properties([
    pipelineTriggers([
        triggers: [
            [
                $class: 'GenericTrigger',
                genericVariables: [
                    [key: 'triggerSource', value: '$.source']
                ],
                token: 'ct-trigger-token'
            ]
        ]
    ])
])

pipeline {
    agent any
    
    environment {
        ECR_REPOSITORY = credentials('ECR_REPOSITORY')
        AWS_ACCOUNT_ID = credentials('AWS_ACCOUNT_ID')
        AWS_ACCESS_KEY_ID = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
        AWS_REGION = 'us-east-1'
        ECS_CLUSTER = 'chest-ct-cluster'
        ECS_SERVICE = 'chest-ct-service'
        MODEL_BUCKET = 'chest-ct-models-155407238003'
    }
    
    stages {
        stage('Trigger Info') {
            steps {
                script {
                    if (env.triggerSource == 'ct-trigger') {
                        echo "🔄 Build triggered by Continuous Training (AWS Batch)"
                    } else {
                        echo "📦 Build triggered manually or by other source"
                    }
                }
            }
        }
        
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code checked out from GitHub"
            }
        }
        
        stage('Download Model from S3') {
            steps {
                script {
                    sh """
                        # Try production path first (from CT), then fallback to root
                        aws s3 cp s3://${MODEL_BUCKET}/production/model.h5 model.h5 || \
                        aws s3 cp s3://${MODEL_BUCKET}/model.h5 model.h5 || \
                        echo "No model found, using default"
                    """
                    echo "✅ Model download attempted"
                }
            }
        }
        
        stage('Continuous Integration') {
            steps {
                script {
                    echo "Linting repository"
                    echo "Running unit tests"
                }
            }
        }

        stage('Login to ECR') {
            steps {
                script {
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                }
            }
        }

        stage('Build Image') {
            steps {
                script {
                    sh "docker build -t ${ECR_REPOSITORY}:latest ."
                }
            }
        }

        stage('Push Image') {
            steps {
                script {
                    sh "docker push ${ECR_REPOSITORY}:latest"
                }
            }
        }

        stage('Deploy to ECS') {
            steps {
                script {
                    sh """
                        aws ecs update-service \
                            --cluster ${ECS_CLUSTER} \
                            --service ${ECS_SERVICE} \
                            --force-new-deployment \
                            --region ${AWS_REGION}
                        
                        aws ecs wait services-stable \
                            --cluster ${ECS_CLUSTER} \
                            --services ${ECS_SERVICE} \
                            --region ${AWS_REGION}
                    """
                    echo "✅ ECS service updated"
                }
            }
        }
        
        stage('Health Check') {
            steps {
                script {
                    sh """
                        sleep 10
                        curl -f http://\$(cd terraform && terraform output -raw load_balancer_dns 2>/dev/null || echo 'pending')/health || echo 'Health check pending'
                    """
                    echo "✅ Health check completed"
                }
            }
        }
    }

    post {
        success {
            echo """
            ========================================
            🎉 DEPLOYMENT SUCCESSFUL! 🎉
            ========================================
            ECS Cluster: ${ECS_CLUSTER}
            ECS Service: ${ECS_SERVICE}
            Trigger Source: ${env.triggerSource ?: 'manual'}
            ========================================
            """
        }
        failure {
            echo """
            ========================================
            ❌ DEPLOYMENT FAILED! ❌
            ========================================
            Check Jenkins console for details.
            ========================================
            """
        }
        always {
            sh 'docker system prune -f || true'
        }
    }
}

